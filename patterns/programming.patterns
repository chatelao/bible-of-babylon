    message = "Error"
    syntax = "    brk #0"
    notes = "The brk instruction triggers a breakpoint exception."
}

instance ArmAarch64Thread of Thread {
    body = { call do_work() }
    syntax = "    mov x8, #220 // clone syscall\n    svc #0"
    notes = "Thread creation typically involves invoking OS system calls (e.g., clone on Linux)."
}

instance ArmAarch64SendMessage of SendMessage {
    recipient = "tid"
    message = "msg"
    syntax = "    mov x8, #139 // rt_sigqueueinfo\n    svc #0"
    notes = "Inter-process/thread communication is managed via OS system calls."
}

instance ArmAarch64ReceiveMessage of ReceiveMessage {
    match_pattern = "msg"
    body = { call handle(msg) }
    syntax = "    mov x8, #128 // rt_sigtimedwait\n    svc #0"
    notes = "Receiving signals or messages involves OS system calls."
}

