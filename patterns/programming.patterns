instance ArmAarch64Var of VariableDeclaration {
    name = "x"
    type = ".quad"
    initial_value = 42
    syntax = "x:  .quad 42"
    notes = "Defined in the .data section."
}

instance ArmAarch64IfElse of IfElse {
    condition = "x0 > 0"
    then_branch = { return 1 }
    else_branch = { return 0 }
    syntax = "    cmp x0, #0\n    ble .else\n    mov x0, #1\n    b .end\n.else:\n    mov x0, #0\n.end:"
    notes = "Implemented using comparison and branch instructions (ble)."
}

instance ArmAarch64Loop of Loop {
    condition = "x0 > 0"
    body = { raw "sub x0, x0, #1" }
    syntax = ".loop:\n    cmp x0, #0\n    ble .end\n    sub x0, x0, #1\n    b .loop\n.end:"
    notes = "Uses conditional branches to implement loops."
}

instance ArmAarch64Function of FunctionDefinition {
    name = "add"
    parameters = ["x0", "x1"]
    return_type = "x0"
    body = { raw "add x0, x0, x1\nret" }
    syntax = "add:\n    add x0, x0, x1\n    ret"
    notes = "Standard AArch64 calling convention; x0-x7 are argument registers, x0 is the return register."
}

instance ArmAarch64Procedure of ProcedureDefinition {
    name = "log_message"
    parameters = ["x0"]
    body = { raw "bl printf" }
    syntax = "log_message:\n    stp x29, x30, [sp, -16]!\n    mov x29, sp\n    bl printf\n    ldp x29, x30, [sp], 16\n    ret"
    notes = "Uses stp/ldp to save and restore the frame pointer (x29) and link register (x30)."
}

instance ArmAarch64TryCatch of TryCatch {
    try_body = { call do_something() }
    exception_type = "N/A"
    error_variable = "N/A"
    catch_body = { raw "/* Manual error checking or trap handling */" }
